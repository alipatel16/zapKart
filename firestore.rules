rules_version = '2';

// ================================================================
// ZAP DELIVERY — FIRESTORE SECURITY RULES
// ================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthed() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthed() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function incomingData() {
      return request.resource.data;
    }

    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isAuthed() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /stores/{storeId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /banners/{bannerId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      // ✅ SECURITY FIX: Removed the stock-only update exception that allowed
      // any logged-in user to directly modify product stock from the client.
      // Stock is now managed exclusively by Firebase Cloud Functions:
      //   • Order created  → validateAndProcessOrder deducts stock
      //   • Order cancelled → notifyUserOnStatusChange restores stock
      //   • Purchase added  → AdminPurchases.jsx (admin only via isAdmin check)
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthed() &&
        (request.auth.uid == resource.data.userId || isAdmin());

      allow create: if isAuthed() &&
        request.auth.uid == incomingData().userId &&
        incomingData().storeId != null;

      // Users can cancel their own order if still in placed/confirmed status.
      // Admins can update any field.
      allow update: if isAdmin() ||
        (isAuthed() &&
         request.auth.uid == resource.data.userId &&
         (resource.data.status == 'placed' || resource.data.status == 'confirmed') &&
         incomingData().status == 'cancelled');

      allow delete: if isAdmin();
    }

    match /purchases/{purchaseId} {
      allow read, write: if isAdmin();
    }

    match /inventory/{itemId} {
      allow read, write: if isAdmin();
    }

    match /fcmTokens/{tokenId} {
      allow read:           if isAdmin();
      allow create, update: if isAuthed();
      allow delete:         if isAuthed();
    }
  }
}
